    function renderResults(results) {
      if (!results.length) return '<div class="f1-empty-state">No results available.</div>';
      let html = '<table class="f1-results-table"><thead><tr><th>Pos</th><th style="text-align:left">Driver</th><th>Team</th><th>Grid</th><th>Time/Gap</th><th>Pts</th></tr></thead><tbody>';
      for (const r of results) {
        const posClass = r.position <= 3 ? `f1-pos-${r.position}` : '';
        const gridDiff = r.grid_position && r.position ? r.grid_position - r.position : r.grid && r.position ? r.grid - r.position : 0;
        const gridVal = r.grid_position || r.grid || 0;
        const gridStr = gridVal ? `${gridVal}${gridDiff > 0 ? ` <span style="color:var(--green)">▲${gridDiff}</span>` : gridDiff < 0 ? ` <span style="color:var(--red)">▼${Math.abs(gridDiff)}</span>` : ''}` : '-';
        html += `<tr class="${posClass}"><td class="f1-result-pos">${r.position}</td><td style="text-align:left"><span class="f1-driver-num" style="color:${r.team_color||r.color||'#fff'}">${r.driver_number||r.number||''}</span> <strong>${r.full_name||r.driver}</strong></td><td class="f1-team-name">${r.team_name||r.team}</td><td>${gridStr}</td><td>${r.gap||r.time||r.status||''}</td><td>${r.points||''}</td></tr>`;
      }
      return html + '</tbody></table>';
    }

    function renderStrategy(strategy) {
      if (!strategy.length) return '<div class="f1-empty-state">No strategy data.</div>';
      let html = '<div class="f1-strategy-grid">';
      for (const s of strategy) {
        html += `<div class="f1-strategy-row"><span class="f1-strategy-driver" style="color:${s.color||'#fff'}">${s.abbreviation||s.driver}</span><div class="f1-stints">`;
        for (const stint of s.stints || []) {
          const width = Math.max(20, (stint.laps || 10) * 5);
          const color = COMPOUND_COLORS[stint.compound] || '#888';
          const textColor = COMPOUND_TEXT[stint.compound] || '#000';
          html += `<div class="f1-stint" style="width:${width}px;background:${color};color:${textColor}" title="${stint.compound} L${stint.start_lap}-${stint.end_lap} (tyre age: ${stint.tyre_age_end||stint.tyre_age||0})">${stint.compound?.charAt(0)||'?'}</div>`;
        }
        html += '</div></div>';
      }
      return html + '</div>';
    }

    function renderWeather(weather) {
      if (!weather.length) return '<div class="f1-empty-state">No weather data.</div>';
      const avg = (arr, key) => { const vals = arr.filter(x => x[key]).map(x => x[key]); return vals.length ? (vals.reduce((a,b) => a+b, 0) / vals.length).toFixed(1) : '—'; };
      const hasRain = weather.some(w => w.rainfall);
      return `<div class="f1-weather-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:1rem">
        <div class="stat-card"><div class="stat-number" style="color:var(--red)">${avg(weather,'air_temp')}°</div><div class="stat-label">Air Temp</div></div>
        <div class="stat-card"><div class="stat-number" style="color:var(--gold)">${avg(weather,'track_temp')}°</div><div class="stat-label">Track Temp</div></div>
        <div class="stat-card"><div class="stat-number" style="color:var(--cyan)">${avg(weather,'humidity')}%</div><div class="stat-label">Humidity</div></div>
        <div class="stat-card"><div class="stat-number" style="color:var(--purple)">${avg(weather,'wind_speed')} m/s</div><div class="stat-label">Wind Speed</div></div>
        <div class="stat-card"><div class="stat-number" style="color:${hasRain?'var(--blue)':'var(--text-dim)'}">${hasRain?'🌧️ Yes':'☀️ No'}</div><div class="stat-label">Rainfall</div></div>
      </div>`;
    }

    function renderRaceControl(messages) {
      if (!messages.length) return '<div class="f1-empty-state">No race control messages.</div>';
      let html = '<div class="event-list">';
      for (const msg of messages) {
        const flagIcon = {'GREEN':'🟢','YELLOW':'🟡','DOUBLE YELLOW':'🟡🟡','RED':'🔴','CHEQUERED':'🏁'}[msg.flag] || '📻';
        const lapStr = msg.lap ? `L${msg.lap}` : '';
        html += `<div class="event-row"><span class="event-time">${lapStr}</span><span class="event-icon">${flagIcon}</span><div class="event-detail"><div class="event-desc">${msg.message}</div></div></div>`;
      }
      return html + '</div>';
    }

    // ========================================================================
    // F1 - RACE REPLAY (Interactive Lap Chart)
    // ========================================================================
    function drawLapChart() {
      const canvas = document.getElementById('f1LapCanvas');
      if (!canvas) return;

      // Resize for crisp rendering
      const rect = canvas.parentElement?.getBoundingClientRect();
      if (rect && rect.width > 100) {
        canvas.width = Math.floor(rect.width);
        canvas.height = 380;
      }

      const ctx = canvas.getContext('2d');
      const w = canvas.width, h = canvas.height;
      const data = f1State.lapsData || f1State.raceData;
      if (!data) return;

      const allLaps = data.laps || [];
      const drivers = data.drivers || (data.results || []).map(r => ({
        abbr: r.abbreviation || '', number: r.driver_number || r.number || '',
        name: r.full_name || r.driver || '', team: r.team_name || r.team || '', color: r.team_color || r.color || '#fff'
      }));
      const driverMap = {};
      for (const d of drivers) driverMap[d.abbr] = d;

      // Filter drivers based on mode
      let activeDrivers = drivers;
      if (replay.mode === 'top10') {
        const top10 = new Set();
        for (const l of allLaps) {
          if (l.position <= 10) top10.add(l.driver);
        }
        activeDrivers = drivers.filter(d => top10.has(d.abbr));
      }
      if (replay.highlightedDriver) {
        activeDrivers = drivers.filter(d => d.abbr === replay.highlightedDriver);
        // Keep all for context but highlight only one
        activeDrivers = drivers;
      }

      const maxPos = replay.mode === 'top10' ? 10 : Math.max(...allLaps.map(l => l.position), drivers.length);
      const maxLap = replay.maxLap || Math.max(...allLaps.map(l => l.lap), 1);
      const pad = {t:20, r:80, b:30, l:40};

      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0,0,w,h);

      // Grid
      ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
      for (let p = 1; p <= maxPos; p++) {
        const y = pad.t + ((p-1)/((maxPos-1) || 1))*(h-pad.t-pad.b);
        ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(w-pad.r,y); ctx.stroke();
        ctx.fillStyle = '#555'; ctx.font = '11px Inter,sans-serif'; ctx.textAlign = 'right';
        ctx.fillText(p, pad.l-8, y+4);
      }
      // Lap numbers
      const lapStep = Math.max(1, Math.ceil(maxLap / 12));
      for (let l = 1; l <= maxLap; l += lapStep) {
        const x = pad.l + ((l-1)/(maxLap || 1))*(w-pad.l-pad.r);
        ctx.fillStyle = '#555'; ctx.font = '10px Inter,sans-serif'; ctx.textAlign = 'center';
        ctx.fillText(l, x, h - 8);
      }

      // Current lap indicator
      if (replay.currentLap > 0) {
        const cx = pad.l + ((replay.currentLap-1)/(maxLap || 1))*(w-pad.l-pad.r);
        ctx.strokeStyle = 'rgba(255,255,255,0.3)'; ctx.lineWidth = 2; ctx.setLineDash([4,4]);
        ctx.beginPath(); ctx.moveTo(cx, pad.t); ctx.lineTo(cx, h-pad.b); ctx.stroke();
        ctx.setLineDash([]);
      }

      // Draw lines per driver
      const lapsByDriver = {};
      for (const l of allLaps) {
        if (!lapsByDriver[l.driver]) lapsByDriver[l.driver] = [];
        lapsByDriver[l.driver].push(l);
      }

      for (const driver of activeDrivers) {
        const dl = lapsByDriver[driver.abbr] || [];
        if (!dl.length) continue;

        const isHighlighted = !replay.highlightedDriver || replay.highlightedDriver === driver.abbr;
        const alpha = isHighlighted ? 1 : 0.15;

        ctx.strokeStyle = hexToRGBA(driver.color || '#fff', alpha);
        ctx.lineWidth = isHighlighted ? 2.5 : 1;
        ctx.beginPath();
        let started = false;
        for (const l of dl) {
          if (l.lap > replay.currentLap) break;
          if (!l.position) continue;
          const x = pad.l + ((l.lap-1)/(maxLap || 1))*(w-pad.l-pad.r);
          const y = pad.t + ((l.position-1)/((maxPos-1) || 1))*(h-pad.t-pad.b);
          if (!started) { ctx.moveTo(x,y); started = true; } else ctx.lineTo(x,y);
        }
        ctx.stroke();

        // Label at current position
        if (isHighlighted) {
          const lastVisible = dl.filter(l => l.lap <= replay.currentLap).pop();
          if (lastVisible) {
            const y = pad.t + ((lastVisible.position-1)/(maxPos-1))*(h-pad.t-pad.b);
            ctx.fillStyle = driver.color || '#fff';
            ctx.font = 'bold 10px Inter,sans-serif'; ctx.textAlign = 'left';
            ctx.fillText(driver.abbr, w-pad.r+5, y+4);
          }
        }
      }

      // Legend
      const replayPoints = [];
      for (const driver of activeDrivers) {
        const dl = lapsByDriver[driver.abbr] || [];
        const targetLap = dl.find(l => l.lap === replay.currentLap);
        if (targetLap && targetLap.position) {
          const x = pad.l + ((targetLap.lap-1)/(maxLap || 1))*(w-pad.l-pad.r);
          const y = pad.t + ((targetLap.position-1)/((maxPos-1) || 1))*(h-pad.t-pad.b);
          replayPoints.push({
            x,
            y,
            driver: driver.abbr,
            name: driver.name || driver.abbr,
            team: driver.team || '',
            position: targetLap.position,
            lap: targetLap.lap,
            lap_time: targetLap.lap_time,
            compound: targetLap.compound,
          });
        }
      }
      canvas._replayPoints = replayPoints;

      const legend = document.getElementById('f1-lap-legend');
      if (legend) {
        legend.innerHTML = activeDrivers.slice(0, 20).map(d =>
          `<span class="f1-legend-item ${replay.highlightedDriver === d.abbr ? 'highlighted' : ''}" style="color:${d.color||'#fff'};cursor:pointer" onclick="highlightDriver('${d.abbr}')">● ${d.abbr}</span>`
        ).join(' ');
      }

      if (!canvas._replayHoverAttached) {
        canvas._replayHoverAttached = true;
        canvas.addEventListener('mousemove', (e) => {
          const tooltip = document.getElementById('f1-replay-tooltip');
          if (!tooltip) return;
          const pts = canvas._replayPoints || [];
          if (!pts.length) { tooltip.style.display = 'none'; return; }
          const rect = canvas.getBoundingClientRect();
          const mx = e.clientX - rect.left;
          const my = e.clientY - rect.top;
          let closest = null;
          let closestDist = 24;
          for (const pt of pts) {
            const dist = Math.hypot(mx - pt.x, my - pt.y);
            if (dist < closestDist) {
              closestDist = dist;
              closest = pt;
            }
          }
          if (closest) {
            tooltip.style.display = 'block';
            tooltip.style.left = (mx + 12) + 'px';
            tooltip.style.top = (my - 12) + 'px';
            tooltip.innerHTML = `<strong>${closest.driver}</strong> ${closest.name ? '— ' + closest.name : ''}<br>P${closest.position} · Lap ${closest.lap}<br>${closest.lap_time || '—'}${closest.compound ? ' · ' + closest.compound : ''}`;
          } else {
            tooltip.style.display = 'none';
          }
        });
        canvas.addEventListener('mouseleave', () => {
          const tooltip = document.getElementById('f1-replay-tooltip');
          if (tooltip) tooltip.style.display = 'none';
        });
      }

      updateReplayLeaderboard();
    }

    function updateReplayLeaderboard() {
      const container = document.getElementById('f1-replay-leaderboard');
      if (!container) return;
      const data = f1State.lapsData || f1State.raceData;
      if (!data?.laps) { container.innerHTML = ''; return; }

      const drivers = data.drivers || (data.results || []).map(r => ({
        abbr: r.abbreviation || '', number: r.driver_number || r.number || '',
        name: r.full_name || r.driver || '', team: r.team_name || r.team || '', color: r.team_color || r.color || '#fff'
      }));
      const driverMap = {};
      for (const d of drivers) driverMap[d.abbr] = d;

      // Find position at current lap
      const positions = [];
      for (const l of data.laps) {
        if (l.lap === replay.currentLap && l.position) {
          positions.push({ driver: l.driver, position: l.position, lap_time: l.lap_time, compound: l.compound });
        }
      }
      positions.sort((a, b) => a.position - b.position);

      let html = '<div class="f1-lb-header">POSITIONS — LAP ' + replay.currentLap + '</div>';
      for (const p of positions) {
        const d = driverMap[p.driver] || {};
        const highlighted = replay.highlightedDriver === p.driver ? ' highlighted' : '';
        const compColor = COMPOUND_COLORS[p.compound] || '#666';
        html += `<div class="f1-lb-row${highlighted}" onclick="highlightDriver('${p.driver}')">
          <span class="f1-lb-pos">${p.position}</span>
          <span class="f1-lb-name" style="color:${d.color||'#fff'}">${p.driver}</span>
          <span class="f1-lb-time">${p.lap_time || ''}</span>
          <span class="f1-lb-compound" style="background:${compColor}">${p.compound?.charAt(0)||''}</span>
        </div>`;
      }
      container.innerHTML = html;

      // Update lap display
      const cl = document.getElementById('replay-current-lap');
      const ml = document.getElementById('replay-max-lap');
      if (cl) cl.textContent = replay.currentLap;
      if (ml) ml.textContent = replay.maxLap;
    }

    function toggleReplay() {
      if (replay.playing) {
        stopReplay();
      } else {
        replay.playing = true;
        const btn = document.getElementById('replay-play');
        if (btn) btn.textContent = '⏸ Pause';
        const interval = 600 / replay.speed;
        replay.timer = setInterval(() => {
          if (replay.currentLap >= replay.maxLap) { stopReplay(); return; }
          replay.currentLap++;
          const scrubber = document.getElementById('replay-scrubber');
          if (scrubber) scrubber.value = replay.currentLap;
          drawLapChart();
        }, interval);
      }
    }

    function stopReplay() {
      replay.playing = false;
      if (replay.timer) { clearInterval(replay.timer); replay.timer = null; }
      const btn = document.getElementById('replay-play');
      if (btn) btn.textContent = '▶ Play';
    }

    function resetReplay() {
      stopReplay();
      replay.currentLap = 1;
      const scrubber = document.getElementById('replay-scrubber');
      if (scrubber) scrubber.value = 1;
      drawLapChart();
    }

    function scrubReplay(val) {
      replay.currentLap = parseInt(val);
      drawLapChart();
    }

    function setReplaySpeed(speed) {
      replay.speed = speed;
      document.querySelectorAll('.f1-speed-btn').forEach(b => b.classList.toggle('active', parseFloat(b.textContent) === speed));
      if (replay.playing) { stopReplay(); toggleReplay(); }
    }

    function setReplayMode(mode) {
      replay.mode = mode;
      document.querySelectorAll('.f1-filter-btn').forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
      drawLapChart();
    }

    function highlightDriver(abbr) {
      replay.highlightedDriver = replay.highlightedDriver === abbr ? null : abbr;
      drawLapChart();
      // Re-draw lap times if visible
      const ltPanel = document.getElementById('tab-f1-laptimes');
      if (ltPanel?.classList.contains('active')) drawLapTimes();
    }

    function searchDriver(query) {
      if (!query) { replay.highlightedDriver = null; drawLapChart(); return; }
      const q = query.toUpperCase();
      const data = f1State.lapsData || f1State.raceData;
      const drivers = data?.drivers || data?.results || [];
      const match = drivers.find(d => (d.abbr || d.abbreviation || '').includes(q) || (d.name || d.driver || d.full_name || '').toUpperCase().includes(q));
      if (match) highlightDriver(match.abbr || match.abbreviation);
    }

    // ========================================================================
    // F1 - LAP TIMES CHART
    // ========================================================================
    function drawLapTimes() {
      const canvas = document.getElementById('f1LapTimesCanvas');
      if (!canvas) return;
      const rect = canvas.parentElement?.getBoundingClientRect();
      if (rect && rect.width > 100) {
        canvas.width = Math.floor(rect.width);
        canvas.height = 400;
      }

      const ctx = canvas.getContext('2d');
      const w = canvas.width, h = canvas.height;
      const data = f1State.lapsData || f1State.raceData;
      if (!data?.laps) {
        ctx.fillStyle = '#888'; ctx.font = '14px Inter'; ctx.textAlign = 'center';
        ctx.fillText('No lap data available.', w/2, h/2);
        return;
      }

      const drivers = data.drivers || (data.results || []).map(r => ({
        abbr: r.abbreviation || '', color: r.team_color || r.color || '#fff'
      }));
      const driverMap = {};
      for (const d of drivers) driverMap[d.abbr] = d;

      const showPits = document.getElementById('lt-show-pits')?.checked;
      const showDeleted = document.getElementById('lt-show-deleted')?.checked;
      const searchQuery = document.getElementById('lt-driver-search')?.value?.toUpperCase() || '';

      // Filter laps
      let laps = data.laps.filter(l => l.lap_time_ms && l.lap_time_ms > 0);
      if (!showPits) laps = laps.filter(l => !l.pit_in && !l.pit_out);
      if (!showDeleted) laps = laps.filter(l => !l.deleted);

      // Filter drivers
      let activeDrivers = drivers;
      if (searchQuery) {
        activeDrivers = drivers.filter(d => d.abbr.includes(searchQuery));
      }
      if (replay.highlightedDriver) {
        activeDrivers = drivers.filter(d => d.abbr === replay.highlightedDriver);
      }

      const activeAbbrs = new Set(activeDrivers.map(d => d.abbr));
      laps = laps.filter(l => activeAbbrs.has(l.driver));

      if (!laps.length) {
        ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0,0,w,h);
        ctx.fillStyle = '#888'; ctx.font = '14px Inter'; ctx.textAlign = 'center';
        ctx.fillText('No laps match filters.', w/2, h/2);
        return;
      }

      const pad = {t:30, r:30, b:30, l:70};
      const minTime = Math.min(...laps.map(l => l.lap_time_ms)) * 0.998;
      const maxTime = Math.max(...laps.map(l => l.lap_time_ms)) * 1.002;
      const maxLap = Math.max(...laps.map(l => l.lap));

      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0,0,w,h);

      // Y axis labels
      const timeRange = maxTime - minTime || 1;
      for (let i = 0; i <= 5; i++) {
        const t = minTime + (i/5) * timeRange;
        const y = pad.t + ((t - minTime) / timeRange) * (h - pad.t - pad.b);
        ctx.fillStyle = '#555'; ctx.font = '10px Inter'; ctx.textAlign = 'right';
        ctx.fillText(msToLapTime(t), pad.l - 8, y + 4);
        ctx.strokeStyle = 'rgba(255,255,255,0.03)'; ctx.beginPath();
        ctx.moveTo(pad.l, y); ctx.lineTo(w-pad.r, y); ctx.stroke();
      }

      // Plot points
      for (const l of laps) {
        const x = pad.l + ((l.lap - 1) / maxLap) * (w - pad.l - pad.r);
        const y = pad.t + ((l.lap_time_ms - minTime) / timeRange) * (h - pad.t - pad.b);
        const color = driverMap[l.driver]?.color || '#fff';
        ctx.fillStyle = hexToRGBA(color, l.is_personal_best ? 1 : 0.6);
        const radius = l.is_personal_best ? 4 : 2.5;
        ctx.beginPath(); ctx.arc(x, y, radius, 0, Math.PI * 2); ctx.fill();
      }

      // Store for hover
      canvas._lapsData = laps;
      canvas._lapsDriverMap = driverMap;
      canvas._lapsPad = pad;
      canvas._lapsMinTime = minTime;
      canvas._lapsTimeRange = timeRange;
      canvas._lapsMaxLap = maxLap;

      // Hover handler
      if (!canvas._ltHoverAttached) {
        canvas._ltHoverAttached = true;
        canvas.addEventListener('mousemove', (e) => {
          const tooltip = document.getElementById('f1-laptimes-tooltip');
          if (!tooltip || !canvas._lapsData) return;
          const rect = canvas.getBoundingClientRect();
          const mx = e.clientX - rect.left, my = e.clientY - rect.top;
          const p = canvas._lapsPad;
          let closest = null, closestDist = 20;
          for (const l of canvas._lapsData) {
            const x = p.l + ((l.lap - 1) / canvas._lapsMaxLap) * (canvas.width - p.l - p.r);
            const y = p.t + ((l.lap_time_ms - canvas._lapsMinTime) / canvas._lapsTimeRange) * (canvas.height - p.t - p.b);
            const dist = Math.sqrt((mx-x)**2 + (my-y)**2);
            if (dist < closestDist) { closestDist = dist; closest = l; }
          }
          if (closest) {
            tooltip.style.display = 'block';
            tooltip.style.left = (e.clientX - rect.left + 10) + 'px';
            tooltip.style.top = (e.clientY - rect.top - 10) + 'px';
            tooltip.innerHTML = `<strong>${closest.driver}</strong> Lap ${closest.lap}<br>${closest.lap_time}<br>${closest.compound} · Tyre age ${closest.tyre_life}<br>S1: ${closest.sector1||'—'} S2: ${closest.sector2||'—'} S3: ${closest.sector3||'—'}`;
          } else {
            tooltip.style.display = 'none';
          }
        });
        canvas.addEventListener('mouseleave', () => {
          const tooltip = document.getElementById('f1-laptimes-tooltip');
          if (tooltip) tooltip.style.display = 'none';
        });
      }
    }

    // ========================================================================
    // F1 - TELEMETRY COMPARE
    // ========================================================================
    function renderTelemetrySelectors(year, round) {
      const controls = document.getElementById('f1-telemetry-controls');
      if (!controls || !f1State.telemetryIndex) return;

      const drivers = f1State.telemetryIndex.drivers || [];
      const lapsByDriver = f1State.telemetryIndex.laps_by_driver || {};
      const presets = f1State.telemetryIndex.presets || {};

      let html = '<div class="f1-tel-selectors">';
      html += '<div class="f1-tel-select"><label>Driver A</label><select id="tel-driver-a" onchange="updateTelDriverLaps(\'a\')">';
      for (const d of drivers) html += `<option value="${d}">${d}</option>`;
      html += '</select><select id="tel-lap-a"></select></div>';
      html += '<div class="f1-tel-select"><label>Driver B</label><select id="tel-driver-b" onchange="updateTelDriverLaps(\'b\')">';
      html += '<option value="">— None —</option>';
      for (const d of drivers) html += `<option value="${d}">${d}</option>`;
      html += '</select><select id="tel-lap-b"></select></div>';

      html += '<div class="f1-tel-presets">';
      for (const fl of (presets.fastest_laps || [])) {
        html += `<button class="f1-preset-btn" onclick="loadTelPreset('${fl.driver}',${fl.lap})">${fl.driver} FL</button>`;
      }
      html += '</div>';
      html += '<button class="f1-tel-load-btn" onclick="loadTelemetry()">Load Telemetry</button>';
      html += '</div>';
      controls.innerHTML = html;

      // Init lap dropdowns
      updateTelDriverLaps('a');
      updateTelDriverLaps('b');
    }

    function updateTelDriverLaps(side) {
      const driverSelect = document.getElementById(`tel-driver-${side}`);
      const lapSelect = document.getElementById(`tel-lap-${side}`);
      if (!driverSelect || !lapSelect || !f1State.telemetryIndex) return;
      const driver = driverSelect.value;
      const laps = f1State.telemetryIndex.laps_by_driver?.[driver] || [];
      lapSelect.innerHTML = laps.map(l => `<option value="${l}">${l}</option>`).join('');
    }

    function loadTelPreset(driver, lap) {
      const dd = document.getElementById('tel-driver-a');
      const ld = document.getElementById('tel-lap-a');
      if (dd) dd.value = driver;
      updateTelDriverLaps('a');
      if (ld) ld.value = lap;
    }

    async function loadTelemetry() {
      const dA = document.getElementById('tel-driver-a')?.value;
      const lA = parseInt(document.getElementById('tel-lap-a')?.value);
      const dB = document.getElementById('tel-driver-b')?.value || null;
      const lB = parseInt(document.getElementById('tel-lap-b')?.value) || null;

      if (!dA || !lA) return;

      const y = f1State.year ?? f1State.raceData?.year ?? 2026;
      const r = f1State.round ?? f1State.raceData?.round ?? 1;

      telState.driverA = dA; telState.lapA = lA;
      telState.driverB = dB; telState.lapB = lB;

      // Fetch telemetry A
      const cacheKeyA = `${dA}_${lA}`;
      if (!f1State.telemetryCache[cacheKeyA]) {
        try {
          const res = await fetch(`/api/f1/race/${y}/${r}/telemetry?driver=${dA}&lap=${lA}`);
          if (res.ok) {
            f1State.telemetryCache[cacheKeyA] = await res.json();
          } else if (res.status === 404) {
            alert('Selected telemetry is not cached for this race yet.');
          }
        } catch (e) {
          console.warn('telemetry fetch failed', e);
        }
      }
      telState.dataA = f1State.telemetryCache[cacheKeyA] || null;

      // Fetch telemetry B
      if (dB && lB) {
        const cacheKeyB = `${dB}_${lB}`;
        if (!f1State.telemetryCache[cacheKeyB]) {
          try {
            const res = await fetch(`/api/f1/race/${y}/${r}/telemetry?driver=${dB}&lap=${lB}`);
            if (res.ok) {
              f1State.telemetryCache[cacheKeyB] = await res.json();
            } else if (res.status === 404) {
              alert('Selected comparison telemetry is not cached for this race yet.');
            }
          } catch (e) {
            console.warn('comparison telemetry fetch failed', e);
          }
        }
        telState.dataB = f1State.telemetryCache[cacheKeyB] || null;
      } else {
        telState.dataB = null;
      }

      drawTelemetryChart();
    }

    function drawTelemetryChart() {
      const canvas = document.getElementById('f1TelCanvas');
      if (!canvas) return;
      const rect = canvas.parentElement?.getBoundingClientRect();
      if (rect && rect.width > 100) {
        canvas.width = Math.floor(rect.width);
        canvas.height = 500;
      }

      const ctx = canvas.getContext('2d');
      const w = canvas.width, h = canvas.height;
      const dataA = telState.dataA;
      const dataB = telState.dataB;

      if (!dataA?.samples?.length) {
        ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0,0,w,h);
        ctx.fillStyle = '#888'; ctx.font = '14px Inter'; ctx.textAlign = 'center';
        ctx.fillText('Select a driver and lap, then click "Load Telemetry".', w/2, h/2);
        return;
      }

      const charts = [
        { key: 'speed', label: 'Speed (km/h)', color: '#00e5ff', min: 0, max: 370 },
        { key: 'throttle', label: 'Throttle (%)', color: '#76ff03', min: 0, max: 110 },
        { key: 'brake', label: 'Brake', color: '#ff4757', min: 0, max: 1 },
        { key: 'gear', label: 'Gear', color: '#ffd600', min: 0, max: 9 },
      ];
      const chartH = (h - 40) / charts.length;
      const pad = {l:60, r:20, t:30, b:5};

      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0,0,w,h);

      const colorA = '#00e5ff';
      const colorB = '#ff4757';

      charts.forEach((chart, ci) => {
        const cy = pad.t + ci * chartH;
        const ch = chartH - pad.t - pad.b;

        // Label
        ctx.fillStyle = chart.color; ctx.font = 'bold 11px Inter'; ctx.textAlign = 'left';
        ctx.fillText(chart.label, pad.l, cy + 14);

        // Grid
        ctx.strokeStyle = 'rgba(255,255,255,0.05)';
        ctx.beginPath(); ctx.moveTo(pad.l, cy+ch); ctx.lineTo(w-pad.r, cy+ch); ctx.stroke();

        // Draw trace A
        drawTelTrace(ctx, dataA.samples, chart, cy, ch, w, pad, colorA);
        // Draw trace B
        if (dataB?.samples?.length) {
          drawTelTrace(ctx, dataB.samples, chart, cy, ch, w, pad, colorB);
        }
      });

      // Cursor line
      if (telState.cursorIdx >= 0 && dataA.samples[telState.cursorIdx]) {
        const x = pad.l + (telState.cursorIdx / (dataA.samples.length - 1)) * (w - pad.l - pad.r);
        ctx.strokeStyle = 'rgba(255,255,255,0.5)'; ctx.lineWidth = 1; ctx.setLineDash([3,3]);
        ctx.beginPath(); ctx.moveTo(x, pad.t); ctx.lineTo(x, h); ctx.stroke();
        ctx.setLineDash([]);
      }

      // Legend
      let legend = `<span style="color:${colorA}">● ${telState.driverA} Lap ${telState.lapA}</span>`;
      if (dataB) legend += ` <span style="color:${colorB}">● ${telState.driverB} Lap ${telState.lapB}</span>`;
      ctx.fillStyle = '#fff'; ctx.font = '11px Inter'; ctx.textAlign = 'right';
      ctx.fillText(legend.replace(/<[^>]*>/g, ''), w - pad.r, pad.t + 14);

      // Hover handler
      if (!canvas._telHoverAttached) {
        canvas._telHoverAttached = true;
        canvas.addEventListener('mousemove', (e) => {
          if (!telState.dataA?.samples) return;
          const rect = canvas.getBoundingClientRect();
          const mx = e.clientX - rect.left;
          const idx = Math.round(((mx - 60) / (canvas.width - 80)) * (telState.dataA.samples.length - 1));
          if (idx >= 0 && idx < telState.dataA.samples.length) {
            telState.cursorIdx = idx;
            drawTelemetryChart();
            // Sync track map dot
            drawTrackMap();
          }
        });
      }
    }

    function drawTelTrace(ctx, samples, chart, cy, ch, w, pad, color) {
      const maxVal = chart.max || Math.max(...samples.map(s => s[chart.key] || 0)) * 1.1 || 1;
      ctx.strokeStyle = color; ctx.lineWidth = 1.5; ctx.beginPath();
      for (let i = 0; i < samples.length; i++) {
        const x = pad.l + (i / (samples.length - 1)) * (w - pad.l - pad.r);
        let v = samples[i][chart.key] || 0;
        if (chart.key === 'brake') v = v ? 1 : 0;
        const y = cy + ch - (v / maxVal) * ch;
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.stroke();
    }

    // ========================================================================
    // F1 - TRACK MAP
    // ========================================================================
    function drawTrackMap() {
      const canvas = document.getElementById('f1TrackCanvas');
      if (!canvas) return;
      const rect = canvas.parentElement?.getBoundingClientRect();
      if (rect && rect.width > 100) {
        const size = Math.min(rect.width, 600);
        canvas.width = size;
        canvas.height = size;
      }

      const ctx = canvas.getContext('2d');
      const w = canvas.width, h = canvas.height;
      const map = f1State.trackMapData;

      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0,0,w,h);

      if (!map?.points?.length) {
        ctx.fillStyle = '#888'; ctx.font = '14px Inter'; ctx.textAlign = 'center';
        ctx.fillText('Track map not available.', w/2, h/2);
        return;
      }

      const points = map.points;
      const xs = points.map(p => p.x), ys = points.map(p => p.y);
      const minX = Math.min(...xs), maxX = Math.max(...xs);
      const minY = Math.min(...ys), maxY = Math.max(...ys);
      const rangeX = maxX - minX || 1, rangeY = maxY - minY || 1;
      const scale = Math.min((w - 80) / rangeX, (h - 80) / rangeY);
      const offX = (w - rangeX * scale) / 2;
      const offY = (h - rangeY * scale) / 2;

      function mapX(x) { return offX + (x - minX) * scale; }
      function mapY(y) { return offY + (y - minY) * scale; }

      // Draw track outline
      ctx.strokeStyle = 'rgba(255,255,255,0.3)'; ctx.lineWidth = 6; ctx.lineCap = 'round';
      ctx.beginPath();
      for (let i = 0; i < points.length; i++) {
        const px = mapX(points[i].x), py = mapY(points[i].y);
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();

      // Draw colored speed overlay
      if (points[0].speed !== undefined) {
        for (let i = 1; i < points.length; i++) {
          const speed = points[i].speed || 0;
          const t = Math.min(speed / 350, 1);
          const r = Math.round(255 * (1 - t)), g = Math.round(255 * t);
          ctx.strokeStyle = `rgb(${r},${g},50)`; ctx.lineWidth = 4;
          ctx.beginPath();
          ctx.moveTo(mapX(points[i-1].x), mapY(points[i-1].y));
          ctx.lineTo(mapX(points[i].x), mapY(points[i].y));
          ctx.stroke();
        }
      }

      // Draw corners
      for (const c of (map.corners || [])) {
        const cx = mapX(c.x), cy = mapY(c.y);
        ctx.fillStyle = 'rgba(255,255,255,0.6)'; ctx.font = 'bold 10px Inter'; ctx.textAlign = 'center';
        ctx.fillText(c.number || '', cx, cy - 8);
      }

      // Draw car dot at cursor position
      if (telState.dataA?.samples?.length && telState.cursorIdx >= 0) {
        const sample = telState.dataA.samples[telState.cursorIdx];
        if (sample.x !== undefined && sample.y !== undefined) {
          const dx = mapX(sample.x), dy = mapY(sample.y);
          ctx.fillStyle = '#00e5ff'; ctx.beginPath(); ctx.arc(dx, dy, 6, 0, Math.PI*2); ctx.fill();
          ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.stroke();
        }
      }
      if (telState.dataB?.samples?.length && telState.cursorIdx >= 0) {
        const sample = telState.dataB.samples[telState.cursorIdx];
        if (sample.x !== undefined && sample.y !== undefined) {
          const dx = mapX(sample.x), dy = mapY(sample.y);
          ctx.fillStyle = '#ff4757'; ctx.beginPath(); ctx.arc(dx, dy, 6, 0, Math.PI*2); ctx.fill();
          ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.stroke();
        }
      }
    }

    let trackPlayTimer = null;
    let trackPlaying = false;
    function toggleTrackPlay() {
      if (trackPlaying) { trackPlaying = false; if(trackPlayTimer) clearInterval(trackPlayTimer); const btn=document.getElementById('track-play'); if(btn) btn.textContent='▶ Play'; return; }
      trackPlaying = true;
      const btn = document.getElementById('track-play'); if(btn) btn.textContent='⏸ Pause';
      const scrubber = document.getElementById('track-scrubber');
      trackPlayTimer = setInterval(() => {
        const samples = telState.dataA?.samples;
        if (!samples) { trackPlaying = false; clearInterval(trackPlayTimer); return; }
        telState.cursorIdx = (telState.cursorIdx + 1) % samples.length;
        if (scrubber) scrubber.value = Math.round((telState.cursorIdx / (samples.length - 1)) * 100);
        drawTrackMap();
        drawTelemetryChart();
      }, 50);
    }
    function resetTrackPlay() {
      trackPlaying = false; if(trackPlayTimer) clearInterval(trackPlayTimer);
      telState.cursorIdx = 0;
      const scrubber = document.getElementById('track-scrubber'); if(scrubber) scrubber.value = 0;
      drawTrackMap();
    }
    function scrubTrack(val) {
      const samples = telState.dataA?.samples;
      if (!samples) return;
      telState.cursorIdx = Math.round((val / 100) * (samples.length - 1));
      drawTrackMap();
      drawTelemetryChart();
    }
    function stopTelPlayback() {
      trackPlaying = false; if(trackPlayTimer) { clearInterval(trackPlayTimer); trackPlayTimer = null; }
    }

    // ========================================================================
    // F1 - UTILITY
    // ========================================================================
    function hexToRGBA(hex, alpha) {
      hex = hex.replace('#','');
      if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
      const r = parseInt(hex.substring(0,2), 16);
      const g = parseInt(hex.substring(2,4), 16);
      const b = parseInt(hex.substring(4,6), 16);
      return `rgba(${r},${g},${b},${alpha})`;
    }

    function msToLapTime(ms) {
      const total = ms / 1000;
      const mins = Math.floor(total / 60);
      const secs = (total % 60).toFixed(3);
      return `${mins}:${secs.padStart(6,'0')}`;
    }

    // ========================================================================
    // INIT
    // ========================================================================
    document.getElementById('updateTime').textContent = 'Updated ' + new Date().toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}).toUpperCase() + ' · ' + new Date().toLocaleTimeString('en-US', {hour:'numeric',minute:'2-digit'});
    loadMatches(); setInterval(loadMatches, 30000);
    loadF1();
  </script>
</Layout>
