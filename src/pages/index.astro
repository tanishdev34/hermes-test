        <div class="f1-replay-controls">
          <button class="f1-replay-btn" id="replay-play" onclick="toggleReplay()">▶ Play</button>
          <button class="f1-replay-btn" onclick="resetReplay()">⟲ Reset</button>
          <div class="f1-replay-lap-display">
            <span class="f1-replay-label">LAP</span>
            <span class="f1-replay-current" id="replay-current-lap">1</span>
            <span class="f1-replay-label">/</span>
            <span class="f1-replay-max" id="replay-max-lap">${data.total_laps || '—'}</span>
          </div>
          <input type="range" min="1" max="${data.total_laps || 50}" value="1" class="f1-replay-scrubber" id="replay-scrubber" oninput="scrubReplay(this.value)">
          <div class="f1-replay-speed">
            <button class="f1-speed-btn" onclick="setReplaySpeed(0.5)">0.5x</button>
            <button class="f1-speed-btn active" onclick="setReplaySpeed(1)">1x</button>
            <button class="f1-speed-btn" onclick="setReplaySpeed(2)">2x</button>
            <button class="f1-speed-btn" onclick="setReplaySpeed(4)">4x</button>
          </div>
        </div>
        <div class="f1-replay-mode">
          <button class="f1-filter-btn active" data-mode="top10" onclick="setReplayMode('top10')">Top 10</button>
          <button class="f1-filter-btn" data-mode="all" onclick="setReplayMode('all')">All</button>
          <input type="text" class="f1-driver-search" id="f1-driver-search" placeholder="Search driver..." oninput="searchDriver(this.value)">
        </div>
        <div class="f1-replay-layout">
          <div class="f1-replay-chart-wrap">
            <div class="f1-lap-legend" id="f1-lap-legend"></div>
            <canvas id="f1LapCanvas" width="800" height="380"></canvas>
            <div id="f1-replay-tooltip" class="f1-tooltip" style="display:none"></div>
          </div>
          <div class="f1-replay-leaderboard" id="f1-replay-leaderboard"></div>
        </div>
      </div>`;

      // Lap Times panel
      html += `<div class="tab-panel" id="tab-f1-laptimes">
        <div class="f1-laptimes-controls">
          <label class="f1-filter-toggle"><input type="checkbox" id="lt-show-pits" onchange="drawLapTimes()"> Show pit laps</label>
          <label class="f1-filter-toggle"><input type="checkbox" id="lt-show-deleted" onchange="drawLapTimes()"> Show deleted laps</label>
          <input type="text" class="f1-driver-search" id="lt-driver-search" placeholder="Search driver..." oninput="drawLapTimes()">
        </div>
        <canvas id="f1LapTimesCanvas" width="900" height="400"></canvas>
        <div id="f1-laptimes-tooltip" class="f1-tooltip" style="display:none"></div>
      </div>`;

      // Strategy panel
      html += `<div class="tab-panel" id="tab-f1-strategy">${renderStrategy(data.strategy || [])}</div>`;

      // Telemetry panel
      html += `<div class="tab-panel" id="tab-f1-telemetry">
        <div class="f1-telemetry-controls" id="f1-telemetry-controls"></div>
        <div class="f1-telemetry-charts">
          <canvas id="f1TelCanvas" width="900" height="500"></canvas>
          <div id="f1-telemetry-tooltip" class="f1-tooltip" style="display:none"></div>
        </div>
      </div>`;

      // Track Map panel
      html += `<div class="tab-panel" id="tab-f1-trackmap">
        <div class="f1-track-controls">
          <button class="f1-replay-btn" id="track-play" onclick="toggleTrackPlay()">▶ Play</button>
          <button class="f1-replay-btn" onclick="resetTrackPlay()">⟲ Reset</button>
          <input type="range" min="0" max="100" value="0" class="f1-replay-scrubber" id="track-scrubber" oninput="scrubTrack(this.value)">
        </div>
        <canvas id="f1TrackCanvas" width="600" height="600"></canvas>
