        <button class="modal-tab active" data-tab="f1-results">🏁 Results</button>
        <button class="modal-tab" data-tab="f1-laps">📈 Race Replay</button>
        <button class="modal-tab" data-tab="f1-laptimes">⏱️ Lap Times</button>
        <button class="modal-tab" data-tab="f1-strategy">🛞 Strategy</button>
        <button class="modal-tab" data-tab="f1-telemetry">📊 Telemetry</button>
        <button class="modal-tab" data-tab="f1-trackmap">🗺️ Track Map</button>
        <button class="modal-tab" data-tab="f1-weather">🌤️ Weather</button>
        <button class="modal-tab" data-tab="f1-racecontrol">📻 Race Control</button>
      </div>`;

