---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Header -->
  <header class="header">
    <p class="update-time" id="updateTime"></p>
    <h1 class="title">THE PULSE</h1>
    <p class="subtitle">LIVE SPORTS DASHBOARD</p>
    <p class="tagline">World Cup 2026 match results, standings, and predictions — plus Formula 1 race data and visualizations.</p>
    <div class="stats-row">
      <div class="stat-card"><div class="stat-number" id="stat-games">-</div><div class="stat-label">Games Played</div></div>
      <div class="stat-card"><div class="stat-number" id="stat-goals">-</div><div class="stat-label">Goals Scored</div></div>
      <div class="stat-card"><div class="stat-number" id="stat-teams">-</div><div class="stat-label">Teams in Play</div></div>
      <div class="stat-card"><div class="stat-number" id="stat-fixtures">-</div><div class="stat-label">Fixtures Next</div></div>
    </div>
  </header>

  <!-- WC Matches -->
  <section class="section" id="matches">
    <div class="section-header">
      <div class="section-num">01</div>
      <h2 class="section-title">⚽ World Cup 2026</h2>
      <p class="section-desc">Live matches pinned to top. Click any match for details.</p>
    </div>
    <div class="match-list" id="matchesList">
      <div class="loading"><span class="pulse-dot"></span> Loading matches...</div>
    </div>
  </section>

  <!-- F1 Section -->
  <section class="section" id="f1">
    <div class="section-header">
      <div class="section-num">02</div>
      <h2 class="section-title">🏎️ Formula 1</h2>
      <p class="section-desc">Race results, lap data, tire strategies, and speed visualizations.</p>
    </div>
    <div id="f1Content">
      <div class="loading"><span class="pulse-dot"></span> Loading F1 data...</div>
    </div>
  </section>

  <!-- Match Detail Modal -->
  <div id="matchModal" class="modal-overlay" onclick="if(event.target===this)closeMatch()">
    <div class="modal-content">
      <button class="modal-close" onclick="closeMatch()">✕</button>
      <div id="modalBody"></div>
    </div>
  </div>

  <!-- F1 Race Modal -->
  <div id="f1Modal" class="modal-overlay" onclick="if(event.target===this)closeF1()">
    <div class="modal-content" style="max-width:1100px">
      <button class="modal-close" onclick="closeF1()">✕</button>
      <div id="f1ModalBody"></div>
    </div>
  </div>

  <script is:inline>
    // === FLAGS ===
    const FLAGS = {"Mexico":"🇲🇽","Korea Republic":"🇰🇷","Czechia":"🇨🇿","South Africa":"🇿🇦","Bosnia & Herzegovina":"🇧🇦","Canada":"🇨🇦","Qatar":"🇶🇦","Switzerland":"🇨🇭","Scotland":"🏴󠁧󠁢󠁳󠁣󠁴󠁿","Brazil":"🇧🇷","Morocco":"🇲🇦","Haiti":"🇭🇹","United States":"🇺🇸","Australia":"🇦🇺","Türkiye":"🇹🇷","Paraguay":"🇵🇾","Germany":"🇩🇪","Curaçao":"🇨🇼","Côte d'Ivoire":"🇨🇮","Ecuador":"🇪🇨","Netherlands":"🇳🇱","Japan":"🇯🇵","Sweden":"🇸🇪","Tunisia":"🇹🇳","Belgium":"🇧🇪","Egypt":"🇪🇬","IR Iran":"🇮🇷","New Zealand":"🇳🇿","Spain":"🇪🇸","Cabo Verde":"🇨🇻","Saudi Arabia":"🇸🇦","Uruguay":"🇺🇾","France":"🇫🇷","Senegal":"🇸🇳","Iraq":"🇮🇶","Norway":"🇳🇴","Argentina":"🇦🇷","Algeria":"🇩🇿","Austria":"🇦🇹","Jordan":"🇯🇴","Portugal":"🇵🇹","Congo DR":"🇨🇩","Uzbekistan":"🇺🇿","Colombia":"🇨🇴","England":"🇬🇧","Croatia":"🇭🇷","Ghana":"🇬🇭","Panama":"🇵🇦"};
    function getFlag(name) {
      if (!name) return '🏳️';
      if (FLAGS[name]) return FLAGS[name];
      for (const [k,v] of Object.entries(FLAGS)) {
        if (name.toLowerCase().includes(k.toLowerCase()) || k.toLowerCase().includes(name.toLowerCase())) return v;
      }
      return '🏳️';
    }

    // === WC MATCHES ===
    function renderMatchCard(m, isLive) {
      const d = new Date(m.date);
      const dateStr = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
      const homeName = m.home.name, awayName = m.away.name;
      const homeScore = m.home.score ?? '?', awayScore = m.away.score ?? '?';
      let scoreClass = '';
      if (m.status === 'finished') scoreClass = m.home.score === m.away.score ? 'score-draw' : 'score-win';
      const statusIcon = isLive ? '<span class="live-badge"><span class="live-dot"></span> LIVE</span>' : '';
      const timeBadge = m.status === 'upcoming' ? `<div class="match-time-badge">${dateStr} · ${m.statusDetail || ''}</div>` : '';
      const matchData = JSON.stringify({home: homeName, away: awayName, homeScore: m.home.score, awayScore: m.away.score, date: dateStr, venue: m.venue, statusDetail: m.statusDetail}).replace(/'/g,"&#39;");
      return `<div class="match-card match-group-a clickable" data-match-id="${m.id}" data-match='${matchData}' onclick="openMatch(${m.id})">
        ${statusIcon}
        <div class="match-teams">
          <div class="match-team home"><span>${homeName}</span><span class="match-flag">${getFlag(homeName)}</span></div>
          <span class="match-vs">vs</span>
          <div class="match-team"><span class="match-flag">${getFlag(awayName)}</span><span>${awayName}</span></div>
        </div>
        <div class="match-score ${scoreClass}">${homeScore} — ${awayScore}</div>
        ${timeBadge}
        <div class="match-arrow">→</div>
      </div>`;
    }

    async function loadMatches() {
      const container = document.getElementById('matchesList');
      try {
        const res = await fetch('/api/matches');
        const matches = await res.json();
        if (!matches.length) { container.innerHTML = '<p style="color:var(--text-muted)">No matches found.</p>'; return; }
        const live = matches.filter(m => m.status === 'live');
        const finished = matches.filter(m => m.status === 'finished').sort((a, b) => new Date(b.date) - new Date(a.date));
        const upcoming = matches.filter(m => m.status === 'upcoming').sort((a, b) => new Date(a.date) - new Date(b.date));
        const showFinished = finished.slice(0, 3);
        const showUpcoming = upcoming.slice(0, 3);
        let html = '';
        if (live.length) for (const m of live) html += renderMatchCard(m, true);
        if (showFinished.length) {
          html += '<div class="match-section-label">Completed</div>';
          for (const m of showFinished) html += renderMatchCard(m, false);
          if (finished.length > 3) html += `<a href="/matches" class="view-all-link">View all ${finished.length} completed →</a>`;
        }
        if (showUpcoming.length) {
          html += '<div class="match-section-label">Upcoming</div>';
          for (const m of showUpcoming) html += renderMatchCard(m, false);
          if (upcoming.length > 3) html += `<a href="/matches" class="view-all-link">View all ${upcoming.length} upcoming →</a>`;
        }
        container.innerHTML = html;
        // Update stats
        const goals = matches.reduce((s, m) => s + (m.home.score || 0) + (m.away.score || 0), 0);
        const allTeams = new Set(); matches.forEach(m => { allTeams.add(m.home.name); allTeams.add(m.away.name); });
        const el = id => document.getElementById(id);
        if (el('stat-games')) el('stat-games').textContent = finished.length;
        if (el('stat-goals')) el('stat-goals').textContent = goals;
        if (el('stat-teams')) el('stat-teams').textContent = allTeams.size;
        if (el('stat-fixtures')) el('stat-fixtures').textContent = live.length + upcoming.length;
      } catch (e) { container.innerHTML = '<p style="color:var(--text-muted)">Failed to load matches.</p>'; }
    }

    // === MATCH MODAL ===
    function openMatch(id) {
      const modal = document.getElementById('matchModal');
      const body = document.getElementById('modalBody');
      modal.classList.add('active'); document.body.style.overflow = 'hidden';
      body.innerHTML = '<div class="loading"><span class="pulse-dot"></span> Loading...</div>';
      const card = document.querySelector(`[data-match-id="${id}"]`);
      const info = card ? JSON.parse(card.dataset.match || '{}') : {};
      fetch(`/api/match/${id}`).then(r => r.json()).then(detail => {
        if (detail.error) { body.innerHTML = '<p style="padding:2rem;color:var(--text-muted)">No details available.</p>'; return; }
        body.innerHTML = renderMatchDetail(info, detail);
        setupTabs();
      }).catch(() => { body.innerHTML = '<p style="padding:2rem;color:var(--text-muted)">Failed to load.</p>'; });
    }
    function closeMatch() { document.getElementById('matchModal').classList.remove('active'); document.body.style.overflow = ''; }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeMatch(); closeF1(); } });

    function renderMatchDetail(info, d) {
      const homeName = info.home || 'Home', awayName = info.away || 'Away';
      let html = `<div class="modal-header">
        <div class="modal-group">${info.date || ''} ${info.statusDetail ? '· ' + info.statusDetail : ''}</div>
        <div class="modal-score-row">
          <div class="modal-team-block"><div class="modal-team-flag">${getFlag(homeName)}</div><div class="modal-team-name">${homeName}</div></div>
          <div class="modal-score">${info.homeScore ?? '?'} — ${info.awayScore ?? '?'}</div>
          <div class="modal-team-block"><div class="modal-team-flag">${getFlag(awayName)}</div><div class="modal-team-name">${awayName}</div></div>
        </div>
        ${info.venue ? `<div class="modal-venue">📍 ${info.venue}</div>` : ''}
      </div>`;
      const hasE = d.events?.length > 0, hasL = d.lineups?.length > 0, hasS = d.stats?.length > 0;
      if (hasE || hasL || hasS) {
        html += `<div class="modal-tabs">
          ${hasE ? '<button class="modal-tab active" data-tab="events">⚽ Events</button>' : ''}
          ${hasL ? '<button class="modal-tab' + (!hasE ? ' active' : '') + '" data-tab="lineup">👥 Lineups</button>' : ''}
          ${hasS ? '<button class="modal-tab' + (!hasE && !hasL ? ' active' : '') + '" data-tab="stats">📊 Stats</button>' : ''}
        </div>`;
        if (hasE) html += renderEvents(d.events);
        if (hasL) html += renderLineups(d.lineups);
        if (hasS) html += renderStats(d.stats);
      } else {
        html += '<p style="text-align:center;color:var(--text-muted);padding:2rem;">No detailed data available yet.</p>';
      }
      return html;
    }
    function renderEvents(events) {
      let html = '<div class="tab-panel active" id="tab-events"><div class="event-list">';
      for (const e of events) {
        let icon = '⚽'; if (e.type === 'card') icon = (e.detail||'').toLowerCase().includes('red') ? '🟥' : '🟨'; if (e.type === 'subst') icon = '🔄';
        html += `<div class="event-row"><span class="event-time">${e.time||''}</span><span class="event-icon">${icon}</span><div class="event-detail"><div class="event-player">${getFlag(e.team)} ${e.player}</div>${e.assist?`<div class="event-assist">🅰️ ${e.assist}</div>`:''}${e.detail?`<div class="event-desc">${e.detail}</div>`:''}</div></div>`;
      }
      return html + '</div></div>';
    }
    function renderLineups(lineups) {
      let html = '<div class="tab-panel" id="tab-lineup">';
      for (const l of lineups) {
        html += `<div class="lineup-section"><div class="lineup-team-header"><span class="lineup-team-name">${getFlag(l.team)} ${l.team||l.teamAbbr}</span><span class="lineup-formation">${l.formation||''}</span></div><div class="lineup-grid">`;
        for (const p of (l.xi||[])) html += `<div class="player-row"><span class="player-number">${p.number}</span><span class="player-name">${p.name}</span><span class="player-pos">${p.pos}</span></div>`;
        html += '</div>';
        if (l.subs?.length) { html += '<div class="subs-header">Substitutes</div><div class="subs-grid">'; for (const s of l.subs) html += `<span class="sub-badge">${s.number} ${s.name}</span>`; html += '</div>'; }
        html += '</div>';
      }
      return html + '</div>';
    }
    function renderStats(statsArr) {
      if (!statsArr || statsArr.length < 2) return '';
      const s0 = statsArr[0].stats||{}, s1 = statsArr[1].stats||{}, n0 = statsArr[0].team||'Home', n1 = statsArr[1].team||'Away';
      let html = '<div class="tab-panel" id="tab-stats"><div class="stats-grid">';
      for (const key of Object.keys(s0)) {
        const v0 = parseFloat(s0[key])||0, v1 = parseFloat(s1[key])||0, total = v0+v1||1;
        const p0 = Math.round((v0/total)*100), label = key.replace(/([A-Z])/g,' $1').replace(/^./,s=>s.toUpperCase());
        html += `<div class="stat-name">${n0} — ${label} — ${n1}</div><div class="stat-row"><span class="stat-val left">${s0[key]}</span><div class="stat-bar-container"><div class="stat-bar-left" style="width:${p0}%"></div><div class="stat-bar-right" style="width:${100-p0}%"></div></div><span class="stat-val right">${s1[key]}</span></div>`;
      }
      return html + '</div></div>';
    }
    function setupTabs() {
      document.querySelectorAll('.modal-tab').forEach(tab => {
        tab.addEventListener('click', () => {
          document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
          document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
          tab.classList.add('active');
          const panel = document.getElementById('tab-' + tab.dataset.tab); if (panel) panel.classList.add('active');
        });
      });
    }

    // === F1 ===
    const F1_FLAGS = {"Red Bull":"🇦🇹","Mercedes":"🇩🇪","Ferrari":"🇮🇹","McLaren":"🇬🇧","Aston Martin":"🇬🇧","Alpine":"🇫🇷","Williams":"🇬🇧","RB":"🇮🇹","Sauber":"🇨🇭","Haas":"🇺🇸"};
    async function loadF1() {
      const container = document.getElementById('f1Content');
      try {
        const res = await fetch('/api/f1/season/2025');
        const data = await res.json();
        if (data.error) { container.innerHTML = `<p style="color:var(--text-muted)">${data.error}</p>`; return; }
        let html = '<div class="f1-grid">';
        for (const race of data.races || []) {
          const flag = F1_FLAGS[race.winner_team] || '🏎️';
          html += `<div class="f1-race-card clickable" onclick="openF1Race(${race.year},${race.round})">
            <div class="f1-race-header">
              <span class="f1-round">R${race.round}</span>
              <span class="f1-flag">${race.flag || '🏁'}</span>
            </div>
            <div class="f1-race-name">${race.name}</div>
            <div class="f1-race-circuit">${race.circuit || ''}</div>
            <div class="f1-race-date">${race.date || ''}</div>
            ${race.winner ? `<div class="f1-winner"><span class="f1-winner-label">Winner</span><span class="f1-winner-name">${flag} ${race.winner}</span></div>` : '<div class="f1-upcoming">Upcoming</div>'}
          </div>`;
        }
        html += '</div>';
        // Standings
        if (data.driver_standings?.length) {
          html += '<div class="f1-standings"><h3 class="f1-standings-title">🏆 Driver Championship</h3><div class="f1-standings-list">';
          for (const [i, d] of data.driver_standings.entries()) {
            html += `<div class="f1-driver-row"><span class="f1-pos">${i+1}</span><span class="f1-driver-name">${d.driver}</span><span class="f1-driver-team" style="color:${d.color||'#fff'}">${d.team}</span><span class="f1-driver-pts">${d.points} pts</span></div>`;
          }
          html += '</div></div>';
        }
        container.innerHTML = html;
      } catch (e) { container.innerHTML = '<p style="color:var(--text-muted)">Failed to load F1 data.</p>'; }
    }
    async function openF1Race(year, round) {
      const modal = document.getElementById('f1Modal');
      const body = document.getElementById('f1ModalBody');
      modal.classList.add('active'); document.body.style.overflow = 'hidden';
      body.innerHTML = '<div class="loading"><span class="pulse-dot"></span> Loading race data...</div>';
      try {
        const res = await fetch(`/api/f1/race/${year}/${round}`);
        const data = await res.json();
        if (data.error) { body.innerHTML = `<p style="padding:2rem;color:var(--text-muted)">${data.error}</p>`; return; }
        body.innerHTML = renderF1Race(data);
      } catch (e) { body.innerHTML = '<p style="padding:2rem;color:var(--text-muted)">Failed to load.</p>'; }
    }
    function closeF1() { document.getElementById('f1Modal').classList.remove('active'); document.body.style.overflow = ''; }

    function renderF1Race(data) {
      let html = `<div class="modal-header"><h2 class="section-title" style="font-size:1.5rem">${data.name || 'Race'}</h2><p class="modal-venue">${data.circuit || ''} · ${data.date || ''}</p></div>`;
      // Tabs
      const hasResults = data.results?.length, hasLaps = data.laps?.length, hasStrategy = data.strategy?.length;
      html += `<div class="modal-tabs">
        ${hasResults ? '<button class="modal-tab active" data-tab="f1-results">🏁 Results</button>' : ''}
        ${hasLaps ? '<button class="modal-tab' + (!hasResults ? ' active' : '') + '" data-tab="f1-laps">📈 Lap Chart</button>' : ''}
        ${hasStrategy ? '<button class="modal-tab' + (!hasResults && !hasLaps ? ' active' : '') + '" data-tab="f1-strategy">🛞 Strategy</button>' : ''}
        ${data.fastest_lap ? '<button class="modal-tab" data-tab="f1-fastest">⚡ Fastest Lap</button>' : ''}
      </div>`;
      // Results
      if (hasResults) {
        html += '<div class="tab-panel active" id="tab-f1-results"><table class="f1-results-table"><thead><tr><th>Pos</th><th style="text-align:left">Driver</th><th>Team</th><th>Time/Gap</th><th>Pts</th><th>Best Lap</th></tr></thead><tbody>';
        for (const r of data.results) {
          const posClass = r.position <= 3 ? `f1-pos-${r.position}` : '';
          html += `<tr class="${posClass}"><td class="f1-result-pos">${r.position}</td><td style="text-align:left"><span class="f1-driver-num" style="color:${r.color||'#fff'}">${r.number||''}</span> <strong>${r.driver}</strong></td><td class="f1-team-name">${r.team}</td><td>${r.gap||r.time||''}</td><td>${r.points||''}</td><td>${r.best_lap||''}</td></tr>`;
        }
        html += '</tbody></table></div>';
      }
      // Lap chart (position over laps)
      if (hasLaps) {
        html += '<div class="tab-panel" id="tab-f1-laps"><div class="f1-lap-chart">';
        html += '<div class="f1-lap-legend">' + (data.results||[]).map(r => `<span style="color:${r.color||'#fff'}">● ${r.driver}</span>`).join(' ') + '</div>';
        html += '<canvas id="f1LapCanvas" width="1000" height="400"></canvas>';
        html += '</div></div>';
      }
      // Strategy
      if (hasStrategy) {
        html += '<div class="tab-panel" id="tab-f1-strategy"><div class="f1-strategy-grid">';
        for (const s of data.strategy) {
          html += `<div class="f1-strategy-row"><span class="f1-strategy-driver">${s.driver}</span><div class="f1-stints">`;
          for (const stint of s.stints || []) {
            const width = Math.max(10, (stint.laps || 10) * 3);
            const color = {'SOFT':'#ff3333','MEDIUM':'#ffcc00','HARD':'#eeeeee','INTERMEDIATE':'#00cc66','WET':'#0066ff'}[stint.compound] || '#888';
            html += `<div class="f1-stint" style="width:${width}px;background:${color}" title="${stint.compound} (L${stint.start_lap}-${stint.end_lap})">${stint.compound?.charAt(0)||'?'}</div>`;
          }
          html += '</div></div>';
        }
        html += '</div></div>';
      }
      // Fastest lap
      if (data.fastest_lap) {
        html += `<div class="tab-panel" id="tab-f1-fastest"><div class="f1-fastest-card">
          <div class="f1-fastest-driver">${data.fastest_lap.driver}</div>
          <div class="f1-fastest-time">${data.fastest_lap.time}</div>
          <div class="f1-fastest-info">${data.fastest_lap.team} · Lap ${data.fastest_lap.lap}</div>
        </div></div>`;
      }
      // Draw lap chart after DOM is ready
      if (hasLaps) {
        setTimeout(() => drawLapChart(data), 100);
      }
      setupTabs();
      return html;
    }

    function drawLapChart(data) {
      const canvas = document.getElementById('f1LapCanvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const w = canvas.width, h = canvas.height;
      const drivers = (data.results || []).map(r => r.driver);
      const colors = (data.results || []).map(r => r.color || '#fff');
      const laps = data.laps || [];
      if (!laps.length) return;
      const maxLap = Math.max(...laps.map(l => l.lap));
      const pad = {t:20,r:20,b:30,l:80};
      ctx.fillStyle = '#0a0a0f'; ctx.fillRect(0,0,w,h);
      // Grid
      ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
      for (let p = 1; p <= drivers.length; p++) {
        const y = pad.t + ((p-1)/(drivers.length-1))*(h-pad.t-pad.b);
        ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(w-pad.r,y); ctx.stroke();
        ctx.fillStyle = '#555'; ctx.font = '11px Inter,sans-serif'; ctx.textAlign = 'right';
        ctx.fillText(p, pad.l-5, y+4);
      }
      // Draw lines
      drivers.forEach((driver, di) => {
        ctx.strokeStyle = colors[di]; ctx.lineWidth = 2; ctx.beginPath();
        let started = false;
        for (const l of laps) {
          if (l.driver === driver) {
            const x = pad.l + ((l.lap-1)/maxLap)*(w-pad.l-pad.r);
            const y = pad.t + ((l.position-1)/(drivers.length-1))*(h-pad.t-pad.b);
            if (!started) { ctx.moveTo(x,y); started = true; } else ctx.lineTo(x,y);
          }
        }
        ctx.stroke();
      });
      // Driver labels
      ctx.font = '10px Inter,sans-serif'; ctx.textAlign = 'left';
      drivers.forEach((driver, di) => {
        const lastLap = laps.filter(l => l.driver === driver).pop();
        if (lastLap) {
          const y = pad.t + ((lastLap.position-1)/(drivers.length-1))*(h-pad.t-pad.b);
          ctx.fillStyle = colors[di]; ctx.fillText(driver.split(' ').pop(), w-pad.r+5, y+4);
        }
      });
    }

    // === INIT ===
    document.getElementById('updateTime').textContent = 'Updated ' + new Date().toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}).toUpperCase() + ' · ' + new Date().toLocaleTimeString('en-US', {hour:'numeric',minute:'2-digit'});
    loadMatches(); setInterval(loadMatches, 30000);
    loadF1();
  </script>
</Layout>
